# Database Configuration (optional — server works without it)
# SQLite (default, zero config):
DATABASE_URL="file:./data/app.db"
# PostgreSQL (if you need a full RDBMS):
# DATABASE_URL="postgresql://addon_user:addon_password@localhost:5432/addon_db?schema=public"

# Server Configuration
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# To run multiple boilerplate projects simultaneously, change the ports:
# Project A: PORT=3001, VITE_PORT=5173
# Project B: PORT=3002, VITE_PORT=5174
# (set VITE_PORT in a client/.env file, and VITE_API_URL=http://localhost:3002)
